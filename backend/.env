# ─── My Drive — Production Environment Variables (Hostinger) ──────────────────
# This file has been pre-filled with Hostinger credentials.
# Copy/rename this file to .env on the server before starting the app.
# ──────────────────────────────────────────────────────────────────────────────
# TO CHANGE DATABASE CREDENTIALS IN FUTURE — edit the DATABASE_URL line below:
#   DB_HOST  : 127.0.0.1     (Hostinger requires 127.0.0.1, NOT "localhost")
#   DB_PORT  : 3306
#   DB_NAME  : u638211070_lmx_md
#   DB_USER  : u638211070_lmx_md
#   DB_PASS  : Te@5219981998  (note: @ is encoded as %40 inside the URL)
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Port — Hostinger assigns this automatically via the Node.js manager.
# Leave blank here; Hostinger injects it as an env var.
# PORT=

# ── Database ──────────────────────────────────────────────────────────────────
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# The @ symbol in the password is URL-encoded as %40
DATABASE_URL="mysql://u638211070_lmx_md:Te%405219981998@127.0.0.1:3306/u638211070_lmx_md"

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# To regenerate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="87d0e868cef57533c2c08ddee5dd7f78835bb8c9c9baa37d99b9e30797187bac82f137fbc8e60634bb1d8c114bc58e69c06e4257da2b960f1c47f9489e1015b3"
